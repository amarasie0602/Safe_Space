MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safespace
JWT_SECRET=your_random_secret_key
PORT=5000
# Comma-separated list of allowed frontend origins for CORS in production
# (e.g. https://safespace.vercel.app). Leave unset in local dev — the
# server then reflects any origin so localhost Vite ports just work.
CLIENT_URL=
# Set to "production" on your deploy platform so error responses never
# include a stack trace.
NODE_ENV=
# VAPID key pair for Web Push (booking-status push notifications). Generate
# your own with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
